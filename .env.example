# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production

# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini API (for AI chat)
GEMINI_API_KEY=your-gemini-api-key-here

# AWS (DynamoDB, etc.; prefer ECS task IAM role when possible)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
DYNAMODB_USER_PROFILES_TABLE=user_profiles
DYNAMODB_HEALTH_DATA_TABLE=health_data

# CORS + cookies (comma-separated origins; SESSION_COOKIE_SECURE false for HTTP ALB)
SESSION_COOKIE_SECURE=true
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
